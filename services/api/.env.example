# GiziGo API environment
# Copy to .env and fill in real values. Never commit .env.

# OpenAI-compatible LLM gateway (only used when HUMANIZER_LLM_ENABLED=true)
OPENAI_BASE_URL=http://43.228.214.145:8317/v1
OPENAI_API_KEY=sk-ama
OPENAI_MODEL=gpt-5.4-mini

# Database
# Local dev (docker container): postgresql://gizigo:devpw@127.0.0.1:5433/gizigo
# Production VPS: postgresql://gizigo:<vault>@127.0.0.1:5432/gizigo
DATABASE_URL=postgresql://gizigo:devpw@127.0.0.1:5433/gizigo

# CORS - for production set to https://gizigo.jmola.my.id
CORS_ALLOWED_ORIGIN=http://localhost:5173

# Feature flags
HUMANIZER_LLM_ENABLED=false

# Server
API_HOST=127.0.0.1
API_PORT=8001
LOG_LEVEL=info
